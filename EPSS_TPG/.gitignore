# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/

# ─── Environments ─────────────────────────────────────────────────────────────
venv/
.venv/
env/

# ─── Large Binary Graph Caches ────────────────────────────────────────────────
# PyG serialized tensors (.pt) — regenerate with:
#   python -m epss.run_pipeline --backbone multiview --hybrid ...
# (takes ~2 h for 10K graphs on RTX 5000 Ada; stored in data/*/pyg_dataset/processed/)
*.pt

# ─── External Dataset (from Sec4AI4Aec-EPSS-Enhanced repo, tracked via LFS there) ──
data/epss/final_dataset_with_delta_days.csv
# Derived labeled JSON from the adapter (regenerate with: python -m epss.csv_adapter)
data/epss_sec4ai/labeled_cves.json

# ─── Large Raw / Derived Data Files ───────────────────────────────────────────
# These files exceed GitHub's 100 MB limit or are derived/regeneratable.
# Full rebuild instructions: docs/EPSS_GNN_Technical_Report.md (Section 4)

# Raw NVD full fetch (~120 MB each) — rebuild: python -m epss.data_collector
data/epss_full/nvd_cves.json
data/epss/nvd_cves.json

# Master merged labeled dataset (>85 MB) — derived from NVD + KEV + EPSS + ExploitDB
data/epss_full/labeled_cves.json
data/epss/labeled_cves.json

# 150 MB copy used by epss_full_train/ PyG pipeline
data/epss_full_train/pyg_dataset/raw/labeled_cves.json

# ─── Compressed EPSS Bulk Downloads ───────────────────────────────────────────
# Download from: https://epss.cyentia.com/epss_scores-YYYY-MM-DD.csv.gz
# Then: python -c "from epss.data_collector import load_epss_csv; load_epss_csv(...)"
*.gz

# ─── Model Checkpoints ────────────────────────────────────────────────────────
# Retrain with: python -m epss.run_pipeline ... (see docs/ for full commands)
output/**/best_model.pt
output/epss/best_model.pt

# ─── Run Logs ─────────────────────────────────────────────────────────────────
output/*.log
*.log

# ─── IDE & OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ============================================================================
# Artifact-branch exclusions (artifact/epss-tpg)
# ----------------------------------------------------------------------------
# The following directories are intentionally kept out of the artifact tree.
# They remain on disk for local development but are not part of the artifact.
# ============================================================================

# Chatbot project — separate effort, not part of the EPSS-TPG model.
tpg_chatbot/
docs/chatbot/
docs/TPG_Chatbot_Technical_Report.md

# LaTeX figures, diagrams and write-ups — built artefacts live elsewhere.
EPSS_Latex/

# Unit and integration tests — excluded from the artifact tree.
tests/

# TeX Live installer dropped in the working tree during a tooling setup.
install-tl-*/

# Runtime logs (per-run training output).
logs/
Datasets_information/**/run_logs/

# Per-experiment graph-cache directories that the pipeline regenerates.
# These can grow to hundreds of GB; reviewers rebuild them from the
# source CSVs in the Sec4AI4Aec-EPSS-Enhanced submodules.
data/epss_*/pyg_dataset/
data/no_security_ablation/

# Per-experiment per-CVE prediction CSVs and training history JSONs —
# heavy intermediate artefacts; only the small test_results.json
# summaries are kept in output/.
output/**/predictions_*.csv
output/**/predictions_val.csv
output/**/training_history.json
output/**/*.png
output/no_security_ablation/**/predictions_*.csv
output/no_security_ablation/**/training_history.json
output/no_security_ablation/**/*.png
